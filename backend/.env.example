# Server Configuration
# Port number for the backend server (default: 8080)
PORT=8080

# MongoDB Configuration
# MongoDB connection string
# Get this from MongoDB Atlas (https://www.mongodb.com/atlas)
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string_here

# Cloudinary Configuration
# Used for image upload and storage
# Sign up at https://cloudinary.com to get these credentials

# Your Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Your Cloudinary API key
CLOUDINARY_API_KEY=your_cloudinary_api_key

# Your Cloudinary API secret
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Admin write-route authentication
# Requests must send:
# Authorization: AdminHMAC <key_id>:<unix_timestamp>:<hex_hmac_sha256_signature>
# Signature payload:
# <HTTP_METHOD>\n<request_path>\n<unix_timestamp>\n<content_type>\n<content_length>
# Example request path: /api/skills or /api/projects/123
# Recommended TTL is short to limit replay window.
ADMIN_API_KEY_ID=your_primary_admin_key_id
ADMIN_API_SECRET=your_long_random_primary_admin_secret
ADMIN_API_SECONDARY_KEY_ID=
ADMIN_API_SECONDARY_SECRET=
ADMIN_API_SIGNATURE_TTL_SECONDS=300

# Your OpenAI API secret
OPENAI_API_KEY=your_openai_api_secret
